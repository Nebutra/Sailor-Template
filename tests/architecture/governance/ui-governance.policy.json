{
  "$schema": "./schemas/ui-governance.schema.json",
  "schemaVersion": "1.0.0",
  "policyVersion": "2026.5.0",
  "rawTailwindColorBudgets": [
    {
      "surface": "landing-marketing",
      "root": "apps/landing-page/src",
      "extensions": [".tsx"],
      "excludeContains": ["/(legal)/"],
      "max": 399
    },
    {
      "surface": "web-app",
      "root": "apps/web/src",
      "extensions": [".tsx"],
      "excludeContains": [],
      "max": 88
    }
  ],
  "tokenFormatBudget": {
    "tokenSurfaces": [
      {
        "root": "packages/design/ui/src/theme",
        "extensions": [".ts", ".tsx"]
      },
      {
        "root": "packages/design/theme/themes.css",
        "extensions": [".css"]
      }
    ],
    "maxHexLiterals": 40,
    "maxHslLiterals": 1,
    "minOklchLiterals": 120,
    "allowedHexFiles": ["packages/design/ui/src/theme/tokens.ts"],
    "allowedHslFiles": []
  },
  "motionBoundary": {
    "appSurfaces": ["apps/landing-page/src", "apps/web/src"],
    "allowedFramerMotionImports": [
      "apps/landing-page/src/components/landing/AnimateIn.tsx",
      "apps/landing-page/src/components/landing/GlobalEdgeMap.tsx",
      "apps/landing-page/src/components/landing/ProductDemoSection.tsx",
      "apps/landing-page/src/app/[lang]/(marketing)/layout.tsx",
      "apps/landing-page/src/components/landing/agentic-engineering/TerminalSnippet.tsx",
      "apps/landing-page/src/components/landing/design-system/PipelineCard.tsx",
      "apps/landing-page/src/components/landing/impact/FrictionlessRouting.tsx",
      "apps/landing-page/src/components/landing/impact/ImpactHero.tsx",
      "apps/landing-page/src/components/landing/impact/InfrastructureGrid.tsx",
      "apps/landing-page/src/components/landing/impact/OrganizationalEvolution.tsx",
      "apps/landing-page/src/components/landing/navbar/MobileDrawer.tsx",
      "apps/landing-page/src/components/landing/product-demo/InvoiceCard.tsx",
      "apps/landing-page/src/components/landing/product-demo/LiveMetricsChart.tsx",
      "apps/landing-page/src/components/landing/product-demo/WorkspacesVisuals.tsx",
      "apps/landing-page/src/components/landing/seo-geo/SEOGEOMockup.tsx",
      "apps/landing-page/src/components/landing/use-cases/UseCasesSection.tsx",
      "apps/landing-page/src/components/landing/use-cases/mockups/DesignMockup.tsx",
      "apps/landing-page/src/components/landing/use-cases/mockups/EDAMMockup.tsx",
      "apps/landing-page/src/components/landing/use-cases/mockups/EnterpriseMockup.tsx",
      "apps/landing-page/src/components/landing/use-cases/mockups/IPMockup.tsx",
      "apps/landing-page/src/components/landing/use-cases/mockups/MultimodalMockup.tsx",
      "apps/landing-page/src/components/landing/use-cases/mockups/OPCMockup.tsx",
      "packages/design/ui/src/components/animate-in.tsx"
    ]
  },
  "componentTierCoverage": {
    "primitivesRoot": "packages/design/ui/src/primitives",
    "tiers": [
      {
        "name": "tier-1",
        "requiredCoverage": 1,
        "components": [
          "button",
          "input",
          "textarea",
          "checkbox-group",
          "combobox",
          "command-menu",
          "dialog",
          "popover",
          "select",
          "tabs",
          "tooltip",
          "skeleton",
          "switch"
        ]
      }
    ]
  },
  "dependencyBoundaries": {
    "appSurfaces": ["apps/landing-page/src", "apps/web/src"],
    "forbiddenImportRegexes": ["^@nebutra\\/[^\\/]+\\/[^\\/]+\\/.+"],
    "customUiAllowedExports": [
      ".",
      "./components",
      "./hooks",
      "./icons",
      "./layout",
      "./layouts",
      "./patterns",
      "./primitives",
      "./tailwind.preset",
      "./theme",
      "./typography",
      "./typography/fonts.css",
      "./utils"
    ]
  },
  "dashboardExperience": {
    "rules": [
      {
        "name": "web-dashboard-overview-high-resolution-density",
        "description": "Dashboard overview must be decision-led and capability-backed; it must not fabricate empty modules, onboarding billboards, or mock metric cards before real data exists.",
        "file": "apps/web/src/app/[locale]/(app)/page.tsx",
        "requiredContains": [
          "CommandCenter",
          "max-w-[1440px]",
          "if (!tenantId) return null",
          "if (!summary?.day) return null",
          "snapshotMeta",
          "meta.snapshot",
          "meta.cadence",
          "meta.tenant",
          "2xl:grid-cols-4",
          "RecentSessions"
        ],
        "forbiddenContains": [
          "DashboardHint",
          "GettingStarted",
          "OnboardingSkeleton",
          "CommandSurfaceButton",
          "ModePills",
          "demo_org",
          "empty.noSnapshot",
          "empty.pending",
          "Atmospheric brand glow",
          "max-w-2xl flex-col items-center",
          "type MetricMeta",
          "dailyMeta",
          "<dl",
          "text-3xl font-semibold tabular-nums"
        ]
      },
      {
        "name": "web-dashboard-loading-state-matches-final-ia",
        "description": "Skeletons must mirror the final dashboard information architecture so loading does not feel like a different product.",
        "file": "apps/web/src/app/[locale]/(app)/_dashboard-skeletons.tsx",
        "requiredContains": ["max-w-3xl", "metricCards", "h-28"],
        "forbiddenContains": [
          "OnboardingSkeleton",
          "space-y-px overflow-hidden",
          "lg:grid-cols-[minmax(0,1fr)_minmax(26rem,34rem)]",
          "max-w-2xl space-y-4 text-center",
          "justify-center"
        ]
      },
      {
        "name": "web-dashboard-recent-sessions-real-only",
        "description": "Recent sessions should render only when real persisted sessions exist; the dashboard must not show an empty working queue as product chrome.",
        "file": "apps/web/src/components/onboarding/recent-sessions.tsx",
        "requiredContains": [
          "if (sessions.length === 0) return null",
          "space-y-2",
          "formatSessionTime"
        ],
        "forbiddenContains": ["emptyTitle", "emptyDescription", "border-dashed"]
      },
      {
        "name": "web-dashboard-header-chrome-single-source",
        "description": "Dashboard header chrome must stay quiet and single-purpose: one page title, progressive breadcrumb only when useful, no duplicated top nav.",
        "file": "apps/web/src/app/[locale]/providers/design-system-shell.tsx",
        "requiredContains": [
          "currentBreadcrumb?.label ?? \"Dashboard\"",
          "breadcrumbs.length <= 1 && \"sr-only\"",
          "aria-label=\"Open feedback dialog\"",
          "BrandLogo",
          "webBrandLabels.homeLink",
          "flex shrink-0 items-center gap-1.5",
          "<span className=\"hidden xl:inline\">Feedback</span>"
        ],
        "forbiddenContains": [
          "DASHBOARD_NAV_ITEMS.slice",
          "planBadge",
          "Nebutra Sailor",
          "role=\"img\"",
          "Workspace</p>",
          "className=\"hidden gap-2 md:flex\""
        ]
      },
      {
        "name": "web-brand-assets-single-source",
        "description": "Web brand chrome must consume synced logo assets from packages/design/brand instead of retyping or redrawing the brand in app components.",
        "file": "apps/web/src/components/brand/brand-assets.tsx",
        "requiredContains": [
          "source: \"packages/design/brand\"",
          "src: \"/brand/logo-color.svg\"",
          "src: \"/brand/logo-horizontal-en.svg\"",
          "data-brand-source={webBrandAssets.source}",
          "alt=\"\""
        ],
        "forbiddenContains": ["Nebutra Sailor", "alt=\"Nebutra\""]
      },
      {
        "name": "web-public-chrome-brand-assets",
        "description": "Public recovery chrome should reuse the governed brand logo primitive and labels instead of raw logo image tags or hardcoded brand labels.",
        "file": "apps/web/src/components/navigation/public-page-chrome.tsx",
        "requiredContains": [
          "BrandLogo",
          "webBrandLabels.homeLink",
          "webBrandLabels.primaryNavigation"
        ],
        "forbiddenContains": [
          "src=\"/brand/logo-horizontal-en.svg\"",
          "alt=\"Nebutra\"",
          "aria-label=\"Nebutra\""
        ]
      },
      {
        "name": "web-theme-playground-single-brand-anchor",
        "description": "Theme Playground content chrome must not repeat the global sidebar brand; the page header should carry product context only.",
        "file": "apps/web/src/components/theme-playground/theme-playground-workbench.tsx",
        "requiredContains": ["Theme Playground", "Token governance workbench"],
        "forbiddenContains": [
          "BrandLogo",
          "ThemeBrandMark",
          "function NebutraMark",
          "font-semibold text-base text-foreground\">Nebutra",
          "grid size-7 place-items-center rounded-[var(--radius-md)] border border-primary/30"
        ]
      },
      {
        "name": "web-dashboard-plan-status-billing-context-only",
        "description": "Plan status must stay in subscription or billing context, not as an ambiguous standalone header chip.",
        "file": "apps/web/src/components/billing/plan-badge.tsx",
        "requiredContains": [
          "subscription status for billing/account surfaces",
          "data-tour-id=\"plan-badge\"",
          "flex flex-wrap items-center gap-2"
        ],
        "forbiddenContains": ["shell header", "hidden items-center gap-2 sm:flex"]
      },
      {
        "name": "web-dashboard-header-locale-normalization",
        "description": "Dashboard navigation state and breadcrumbs must normalize locale-prefixed routes from the shared i18n routing source.",
        "file": "apps/web/src/app/[locale]/providers/dashboard-nav.ts",
        "requiredContains": [
          "import { routing } from \"@nebutra/i18n/routing\";",
          "const LOCALE_PREFIXES = new Set<string>(routing.locales)",
          "export function stripLocalePrefix(pathname: string)",
          "const normalizedPathname = stripLocalePrefix(pathname);",
          "const segments = stripLocalePrefix(pathname).split(\"/\").filter(Boolean);"
        ],
        "forbiddenContains": [
          "const LOCALE_PREFIXES = new Set([\"en\", \"zh\"]);",
          ".filter((segment, index) => index > 0 || !LOCALE_PREFIXES.has(segment))"
        ]
      },
      {
        "name": "web-dashboard-copy-tokenized-for-locales",
        "description": "Dashboard experience copy must live in shared i18n messages so governance covers English and Chinese routes together.",
        "file": "packages/platform/i18n/locales/en.json",
        "requiredContains": [
          "\"commandCenter\"",
          "\"snapshot\": \"Snapshot\"",
          "\"cadence\": \"Cadence\"",
          "\"tenant\": \"Tenant\""
        ],
        "forbiddenContains": [
          "\"No recent sessions yet\"",
          "\"emptyTitle\"",
          "\"noSnapshot\"",
          "\"pending\": \"Pending\""
        ]
      },
      {
        "name": "web-dashboard-zh-copy-tokenized-for-locales",
        "description": "Chinese dashboard copy must stay in the shared i18n layer, not hardcoded in app components.",
        "file": "packages/platform/i18n/locales/zh.json",
        "requiredContains": [
          "\"commandCenter\"",
          "\"snapshot\": \"快照\"",
          "\"cadence\": \"频率\"",
          "\"tenant\": \"租户\""
        ],
        "forbiddenContains": [
          "\"暂无最近会话\"",
          "\"emptyTitle\"",
          "\"noSnapshot\"",
          "\"pending\": \"待连接\""
        ]
      }
    ]
  },
  "budgets": {
    "rawTailwindColors": {
      "description": "Raw Tailwind color utilities (bg-slate-*, text-gray-*, etc.) — use semantic tokens instead",
      "max": 1064,
      "paths": ["packages/design/ui/src/**", "apps/web/src/**", "apps/landing-page/src/**"],
      "exclude": ["**/*.stories.*", "**/globals.css"]
    },
    "rawTailwindBorderRadius": {
      "description": "Raw Tailwind border-radius utilities — use var(--radius-*) tokens instead",
      "max": 556,
      "paths": ["packages/design/ui/src/**", "apps/web/src/**", "apps/landing-page/src/**"],
      "exclude": ["**/*.stories.*"]
    }
  }
}
