{
  "name": "@nebutra/design-docs",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "predev": "fumadocs-mdx && node scripts/build-registry.mjs && tsx ../../packages/design/ui/scripts/build-registry.ts",
    "dev": "next dev --port 3003",
    "prebuild": "fumadocs-mdx && node scripts/build-registry.mjs && tsx ../../packages/design/ui/scripts/build-registry.ts",
    "build": "_FUMADOCS_MDX=1 next build",
    "start": "next start",
    "typecheck": "fumadocs-mdx && _FUMADOCS_MDX=1 next typegen && tsc --noEmit",
    "lint:links": "node ./scripts/lint-links.mjs",
    "sync-obsidian": "tsx scripts/sync-obsidian.ts",
    "sync-python": "node scripts/generate-python-docs.mjs",
    "clean": "rm -rf .next"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@ai-sdk/react": "^3.0.118",
    "@fumadocs/mdx-remote": "^1.4.6",
    "@fumadocs/story": "^0.0.11",
    "@nebutra/brand": "workspace:*",
    "@nebutra/icons": "workspace:*",
    "@nebutra/tokens": "workspace:*",
    "@nebutra/ui": "workspace:*",
    "@takumi-rs/image-response": "^0.71.4",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "framer-motion": "^12.35.0",
    "geist": "catalog:",
    "fumadocs-core": "catalog:",
    "fumadocs-mdx": "catalog:",
    "fumadocs-mermaid": "^1.3.1",
    "fumadocs-obsidian": "^0.0.13",
    "fumadocs-openapi": "^10.3.17",
    "fumadocs-python": "^0.0.9",
    "fumadocs-typescript": "^5.1.5",
    "fumadocs-ui": "catalog:",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "mermaid": "^11.15.0",
    "motion": "^12.35.0",
    "next": "^16.2.6",
    "octokit": "^5.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.7.1",
    "rehype-mermaid": "^3.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "unist-util-visit": "^5.1.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jiti": "^2.6.1",
    "next-validate-link": "^1.6.4",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  },
  "license": "AGPL-3.0-only"
}
