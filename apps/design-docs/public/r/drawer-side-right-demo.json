  "files": [
    {
      "path": "registry/examples/drawer-side-right-demo.tsx",
      "content": "\"use client\";\n\nimport {\n  Button,\n  Drawer,\n  DrawerBody,\n  DrawerClose,\n  DrawerContent,\n  DrawerFooter,\n  DrawerHeader,\n  DrawerTitle,\n  DrawerTrigger,\n} from \"@nebutra/ui/primitives\";\n\nexport function DrawerSideRightDemo() {\n  return (\n    <Drawer height={260}>\n      <DrawerTrigger asChild>\n        <Button variant=\"outline\">Open Drawer</Button>\n      </DrawerTrigger>\n      <DrawerContent>\n        <DrawerHeader>\n          <DrawerTitle>Mobile Action</DrawerTitle>\n        </DrawerHeader>\n        <DrawerBody>\n          <p className=\"text-sm text-muted-foreground\">\n            Use Sheet for side panels; Drawer stays a mobile bottom sheet.\n          </p>\n        </DrawerBody>\n        <DrawerFooter>\n          <DrawerClose asChild>\n            <Button variant=\"outline\">Cancel</Button>\n          </DrawerClose>\n        </DrawerFooter>\n      </DrawerContent>\n    </Drawer>\n  );\n}\n",
      "type": "registry:example"
    }
  ]
}
