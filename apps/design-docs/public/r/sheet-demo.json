{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "sheet-demo",
  "type": "registry:example",
  "dependencies": [
    "@nebutra/ui"
  ],
  "registryDependencies": [
    "@nebutra/ui"
  ],
  "files": [
    {
      "path": "registry/examples/sheet-demo.tsx",
      "content": "\"use client\";\n\nimport {\n  Button,\n  Sheet,\n  SheetBody,\n  SheetClose,\n  SheetContent,\n  SheetDescription,\n  SheetFooter,\n  SheetHeader,\n  SheetTitle,\n  SheetTrigger,\n} from \"@nebutra/ui/primitives\";\n\nconst rows = [\n  [\"Status\", \"Ready\"],\n  [\"Region\", \"iad1\"],\n  [\"Last Deployment\", \"2 minutes ago\"],\n] as const;\n\nexport function SheetDemo() {\n  return (\n    <Sheet>\n      <SheetTrigger asChild>\n        <Button variant=\"outline\">Open Sheet</Button>\n      </SheetTrigger>\n      <SheetContent>\n        <SheetHeader>\n          <SheetTitle>Deployment Details</SheetTitle>\n          <SheetDescription>Inspect the deployment without leaving the table.</SheetDescription>\n        </SheetHeader>\n        <SheetBody>\n          <dl className=\"grid gap-3\">\n            {rows.map(([label, value]) => (\n              <div\n                className=\"grid gap-1 rounded-[var(--radius-lg)] border border-border bg-muted/40 p-3\"\n                key={label}\n              >\n                <dt className=\"font-medium text-muted-foreground text-xs\">{label}</dt>\n                <dd className=\"text-foreground text-sm\">{value}</dd>\n              </div>\n            ))}\n          </dl>\n        </SheetBody>\n        <SheetFooter>\n          <SheetClose asChild>\n            <Button variant=\"outline\">Close</Button>\n          </SheetClose>\n          <Button>Open Deployment</Button>\n        </SheetFooter>\n      </SheetContent>\n    </Sheet>\n  );\n}\n",
      "type": "registry:example"
    }
  ]
}
