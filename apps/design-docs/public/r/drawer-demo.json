{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "drawer-demo",
  "type": "registry:example",
  "dependencies": [
    "@nebutra/ui"
  ],
  "registryDependencies": [
    "@nebutra/ui"
  ],
  "files": [
    {
      "path": "registry/examples/drawer-demo.tsx",
      "content": "\"use client\";\n\nimport {\n  Button,\n  Drawer,\n  DrawerBody,\n  DrawerClose,\n  DrawerContent,\n  DrawerDescription,\n  DrawerFooter,\n  DrawerHeader,\n  DrawerTitle,\n  DrawerTrigger,\n} from \"@nebutra/ui/primitives\";\n\nexport function DrawerDemo() {\n  return (\n    <Drawer>\n      <DrawerTrigger asChild>\n        <Button variant=\"outline\">Open Drawer</Button>\n      </DrawerTrigger>\n      <DrawerContent>\n        <DrawerHeader>\n          <DrawerTitle>Filter Logs</DrawerTitle>\n          <DrawerDescription>Choose the log types shown in this view.</DrawerDescription>\n        </DrawerHeader>\n        <DrawerBody>\n          <div className=\"grid gap-2\">\n            {[\"Errors\", \"Warnings\", \"Deployments\"].map((option) => (\n              <label\n                key={option}\n                className=\"flex items-center justify-between rounded-[var(--radius-md)] border bg-card px-3 py-2 text-sm\"\n              >\n                <span>{option}</span>\n                <input type=\"checkbox\" className=\"size-4 accent-primary\" />\n              </label>\n            ))}\n          </div>\n        </DrawerBody>\n        <DrawerFooter>\n          <Button>Apply Filters</Button>\n          <DrawerClose asChild>\n            <Button variant=\"outline\">Cancel</Button>\n          </DrawerClose>\n        </DrawerFooter>\n      </DrawerContent>\n    </Drawer>\n  );\n}\n",
      "type": "registry:example"
    }
  ]
}
