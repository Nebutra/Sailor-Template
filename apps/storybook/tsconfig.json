{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "noEmit": true,
    "exactOptionalPropertyTypes": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": ["../web/src/*"]
    }
  },
  "include": [".storybook/**/*", "src/**/*"],
  "exclude": ["node_modules", "dist"]
}
