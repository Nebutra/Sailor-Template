{
  "crons": [
    {
      "path": "/api/cron/invitation-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/session-cleanup",
      "schedule": "0 4 * * *"
    }
  ],
  "framework": "nextjs",
  "buildCommand": "pnpm turbo build --filter=@nebutra/web",
  "ignoreCommand": "bash ../../scripts/vercel-ignore-build.sh apps/web",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_SITE_URL": "https://app.nebutra.com",
    "NEXT_PUBLIC_API_URL": "https://api.nebutra.com",
    "NEBUTRA_LANDING_ORIGIN": "https://nebutra.com",
    "NEBUTRA_SESSION_HINT_DOMAIN": ".nebutra.com"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), interest-cohort=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.nebutra.com/:path*"
    }
  ]
}
