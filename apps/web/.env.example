# ──────────────────────────────────────────────────────────────────────────
# Auth — three switchable providers via @nebutra/auth
#
# Choose one with AUTH_PROVIDER (server) and NEXT_PUBLIC_AUTH_PROVIDER (client),
# then fill in the matching block below.
#   - clerk      → managed, fastest setup
#   - better-auth→ self-hosted, modern (2FA / passkeys / RBAC)
#   - nextauth   → self-hosted, mature, large OAuth ecosystem (Auth.js v5)
#   - supabase   → hosted auth + realtime/storage ecosystem
#   - dev        → fixture "Dev User" + "pro" workspace, LOCAL ONLY
#                  (hard-fails at module load if NODE_ENV === "production")
# ──────────────────────────────────────────────────────────────────────────
AUTH_PROVIDER=clerk
NEXT_PUBLIC_AUTH_PROVIDER=clerk

# ── Clerk (when AUTH_PROVIDER=clerk) ──
# Clerk Google One Tap is handled by the landing app with Clerk's official
# <GoogleOneTap /> component and this publishable key.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Google OAuth / One Tap (used by Better Auth and NextAuth) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Better Auth (when AUTH_PROVIDER=better-auth) ──
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
# Better Auth Google One Tap uses the official one-tap plugin at:
#   /api/auth/one-tap/callback
# Landing app also needs NEXT_PUBLIC_AUTH_PROVIDER=better-auth and
# NEXT_PUBLIC_GOOGLE_CLIENT_ID set to this same web client id.

# ── NextAuth / Auth.js v5 (when AUTH_PROVIDER=nextauth) ──
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3001
# OAuth providers — leave blank to disable that provider
# Enables the landing-page Google Identity Services One Tap prompt.
# Add this exact URI to the Google OAuth web client's authorized redirect URIs:
#   https://app.nebutra.com/api/auth/google-one-tap
# Landing app also needs NEXT_PUBLIC_AUTH_PROVIDER=nextauth and
# NEXT_PUBLIC_GOOGLE_CLIENT_ID set to the same web client id.
NEBUTRA_LANDING_ORIGIN=https://nebutra.com
NEBUTRA_SESSION_HINT_DOMAIN=.nebutra.com
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Supabase Auth (when AUTH_PROVIDER=supabase) ──
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_WEBHOOK_SECRET=

# ── Dev fixture (when AUTH_PROVIDER=dev — LOCAL PREVIEW ONLY) ──
# No additional config. Set the two AUTH_PROVIDER vars above to `dev` and
# the app will boot as the synthetic "Dev User" with a "pro"-plan workspace
# ("dev-org-001"). Useful for previewing the authenticated shell without a
# real signup. Production builds hard-fail at provider import time, so this
# cannot accidentally ship.

# API Gateway URL
NEXT_PUBLIC_API_URL=http://localhost:3002/api

# ──────────────────────────────────────────────────────────────────────────
# Database (Postgres) — Prisma uses this URL
#
# Use `sslmode=verify-full` explicitly. With `pg` v8.x / `pg-connection-string`
# v2.x, `sslmode=require` is treated as an alias for `verify-full` but emits a
# deprecation warning on every server start; in pg v9 the alias will adopt
# weaker libpq semantics. `verify-full` is what Neon / Supabase managed
# Postgres expect anyway, so this is forwards-compatible.
# ──────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/db?sslmode=verify-full&channel_binding=require

# Warehouse (server-side only)
CLICKHOUSE_HTTP_URL=http://localhost:8123
CLICKHOUSE_DATABASE=nebutra
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
DEFAULT_DASHBOARD_TENANT_ID=demo_org
