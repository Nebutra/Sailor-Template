{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "@nebutra/design-tokens/*": ["../../packages/design/design-tokens/*"],
      "@nebutra/queue": ["../../packages/integrations/queue/src/index.ts"],
      "@nebutra/queue/*": ["../../packages/integrations/queue/src/*"],
      "@nebutra/theme": ["../../packages/design/theme/src/index.ts"],
      "@nebutra/theme/*": ["../../packages/design/theme/src/*"],
      "@nebutra/ui": ["../../packages/design/ui/src/index.ts"],
      "@nebutra/ui/*": ["../../packages/design/ui/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
