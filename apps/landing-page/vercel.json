{
  "framework": "nextjs",
  "buildCommand": "pnpm --filter @nebutra/contracts build && pnpm --filter @nebutra/brand build && pnpm --filter @nebutra/icons build && pnpm --filter @nebutra/billing build && pnpm --filter @nebutra/email build && pnpm --filter @nebutra/landing-page build",
  "ignoreCommand": "bash ../../scripts/vercel-ignore-build.sh apps/landing-page",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_SITE_URL": "https://nebutra.com",
    "NEXT_PUBLIC_API_URL": "https://api.nebutra.com"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api.nebutra.com/:path*"
    }
  ]
}
