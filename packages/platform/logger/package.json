{
  "name": "@nebutra/logger",
  "version": "0.1.1",
  "description": "Structured logging and OpenTelemetry instrumentation for Nebutra services",
  "private": false,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./otel": {
      "types": "./dist/otel.d.ts",
      "import": "./dist/otel.js",
      "default": "./dist/otel.js"
    },
    "./otel-bootstrap": {
      "types": "./dist/otel-bootstrap.d.ts",
      "import": "./dist/otel-bootstrap.js",
      "default": "./dist/otel-bootstrap.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/otel.ts src/otel-bootstrap.ts --format esm --dts --out-dir dist --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation-http": "^0.218.0",
    "@opentelemetry/instrumentation-ioredis": "^0.61.0",
    "@opentelemetry/instrumentation-pg": "^0.65.0",
    "@opentelemetry/instrumentation-pino": "^0.59.0",
    "@opentelemetry/instrumentation-undici": "^0.23.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "langfuse-vercel": "^3.38.20",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "pino-pretty": "^13.1.3",
    "tsup": "catalog:",
    "typescript": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/platform/logger#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/platform/logger"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
