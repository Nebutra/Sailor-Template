{
  "name": "@nebutra/feature-flags",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "description": "Feature flags abstraction - swap providers later",
  "nebutra": {
    "status": "wip",
    "productionReady": false,
    "requires": [
      "@nebutra/cache",
      "@nebutra/db"
    ],
    "gaps": [
      "No production app integrations",
      "Managed providers not wired to real Vercel Flags/GrowthBook/ConfigCat clients",
      "No rollout dashboard or persisted rule store"
    ]
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./react": "./src/react.ts"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/cache": "workspace:*",
    "@nebutra/db": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
