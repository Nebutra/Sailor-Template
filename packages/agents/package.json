{
  "name": "@nebutra/agents",
  "version": "1.0.0",
  "private": true,
  "description": "Nebutra AI runtime: multi-agent orchestration + Vercel AI SDK helpers (absorbed @nebutra/ai-sdk in 1.0.0)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tools": "./src/tools.ts",
    "./providers/vercel-ai": "./src/providers/vercel-ai.ts",
    "./providers/langchain": "./src/providers/langchain.ts",
    "./sdk": "./src/sdk/index.ts",
    "./sdk/config": "./src/sdk/config.ts",
    "./sdk/models": "./src/sdk/models.ts",
    "./sdk/provider": "./src/sdk/provider.ts"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.41",
    "@nebutra/billing": "workspace:*",
    "@nebutra/cache": "workspace:*",
    "@nebutra/logger": "workspace:*",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.0.18"
  }
}
