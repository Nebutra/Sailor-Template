{
  "name": "@nebutra/agents",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-agent orchestration engine for multi-tenant AI applications",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tools": "./src/tools.ts",
    "./providers/vercel-ai": "./src/providers/vercel-ai.ts",
    "./providers/langchain": "./src/providers/langchain.ts"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/billing": "workspace:*",
    "@nebutra/cache": "workspace:*",
    "@nebutra/logger": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
