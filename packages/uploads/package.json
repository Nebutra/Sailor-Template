{
  "name": "@nebutra/uploads",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "nebutra": {
    "status": "foundation",
    "productionReady": false,
    "requires": [
      "AWS_S3_BUCKET + AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY (or R2 equivalents)",
      "or local filesystem for dev"
    ],
    "gaps": [
      "Tus resumable adapter optional-peer, not wired end-to-end",
      "MIME/size validation is stub-level",
      "Virus-scan hook pending"
    ]
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./s3": "./src/providers/s3.js",
    "./local": "./src/providers/local.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@nebutra/logger": "workspace:*",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "tus-js-client": "^4.2.0"
  },
  "peerDependenciesMeta": {
    "tus-js-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "catalog:"
  }
}
