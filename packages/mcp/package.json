{
  "name": "@nebutra/mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "nebutra": {
    "status": "wip",
    "productionReady": false,
    "requires": ["@modelcontextprotocol/sdk runtime"],
    "gaps": [
      "No production app integrations",
      "Context server binary is a placeholder stub",
      "Tool registry + plan-based access control pending"
    ]
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client/index.ts",
    "./server": "./src/server/index.ts",
    "./middleware": "./src/middleware/index.ts"
  },
  "bin": {
    "nebutra-mcp": "./dist/server/contextServer.js"
  },
  "scripts": {
    "prepare": "mkdir -p dist/server && test -f dist/server/contextServer.js || echo '#!/usr/bin/env node' > dist/server/contextServer.js",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
