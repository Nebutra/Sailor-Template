{
  "name": "@nebutra/metering",
  "version": "0.1.0",
  "private": false,
  "license": "AGPL-3.0",
  "type": "module",
  "nebutra": {
    "status": "production",
    "productionReady": true,
    "requires": [
      "CLICKHOUSE_URL or in-memory provider for dev"
    ],
    "gaps": [
      "Retention/TTL policy is operator-driven (apply per environment)",
      "Sharded/replicated topology uses ReplicatedMergeTree — see README"
    ],
    "featureId": "metering",
    "category": "commerce",
    "summary": "Usage metering pipeline — ClickHouse real-time aggregation"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./clickhouse": {
      "types": "./dist/providers/clickhouse.d.ts",
      "import": "./dist/providers/clickhouse.js"
    },
    "./memory": {
      "types": "./dist/providers/memory.d.ts",
      "import": "./dist/providers/memory.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clickhouse/client": "^1.12.0",
    "@nebutra/logger": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/commerce/metering#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/commerce/metering"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
