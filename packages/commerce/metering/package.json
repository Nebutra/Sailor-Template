{
  "name": "@nebutra/metering",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "nebutra": {
    "status": "production",
    "productionReady": true,
    "requires": [
      "CLICKHOUSE_URL or in-memory provider for dev"
    ],
    "gaps": [
      "Retention/TTL policy is operator-driven (apply per environment)",
      "Sharded/replicated topology uses ReplicatedMergeTree — see README"
    ],
    "featureId": "metering",
    "category": "commerce",
    "summary": "Usage metering pipeline — ClickHouse real-time aggregation"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./clickhouse": "./src/providers/clickhouse.ts",
    "./memory": "./src/providers/memory.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clickhouse/client": "^1.12.0",
    "@nebutra/logger": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
