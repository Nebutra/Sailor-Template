{
  "name": "@nebutra/license",
  "version": "0.1.2",
  "description": "License domain logic — issuance, validation, and lifecycle events",
  "private": false,
  "license": "MIT",
  "type": "module",
  "nebutra": {
    "featureId": "license",
    "category": "commerce",
    "summary": "License key generation + validation"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./handlers": {
      "types": "./dist/handlers/index.d.ts",
      "import": "./dist/handlers/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@nebutra/email": "workspace:*",
    "@nebutra/logger": "workspace:*",
    "@nebutra/queue": "workspace:*",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@nebutra/db": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@nebutra/db": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nebutra/db": "workspace:*",
    "@vitest/coverage-v8": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/commerce/license#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/commerce/license"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
