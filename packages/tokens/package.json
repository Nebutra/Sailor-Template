{
  "name": "@nebutra/tokens",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Unified theme tokens and theme-provider entry for Nebutra apps",
  "sideEffects": [
    "./styles.css"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./styles.css"
  },
  "scripts": {
    "prebuild": "pnpm --filter @nebutra/design-tokens build",
    "build": "node -e \"require('node:fs').copyFileSync('../design-tokens/build/css/styles.generated.css', './styles.css'); console.log('styles.css regenerated from @nebutra/design-tokens')\"",
    "sync": "pnpm --filter @nebutra/design-tokens build && node -e \"require('node:fs').copyFileSync('../design-tokens/build/css/styles.generated.css', './styles.css')\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next-themes": "^0.4.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": "^19"
  }
}
