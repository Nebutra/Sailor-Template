    "test:watch": "vitest"
  },
  "dependencies": {
    "@nebutra/billing": "workspace:*",
    "@nebutra/email": "workspace:*",
    "@nebutra/event-bus": "workspace:*"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "^4.0.18"
  }
}
