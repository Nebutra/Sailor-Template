{
  "name": "@nebutra/queue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "nebutra": {
    "status": "foundation",
    "productionReady": false,
    "requires": [
      "QSTASH_TOKEN (+ signing keys) for serverless",
      "or REDIS_URL for BullMQ self-hosted"
    ],
    "gaps": [
      "Dead letter queue not implemented",
      "Worker auto-scaling TODO",
      "SQS and Upstash Kafka adapters not started"
    ]
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./qstash": "./src/providers/qstash.ts",
    "./bullmq": "./src/providers/bullmq.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/logger": "workspace:*",
    "@upstash/qstash": "^2.7.17",
    "bullmq": "^5.34.8",
    "ioredis": "^5.4.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
