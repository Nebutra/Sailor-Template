{
  "name": "@nebutra/cofounder-match",
  "version": "0.1.1",
  "description": "Behavior-verified cofounder profile, matching, and mutual-consent introduction surface",
  "private": false,
  "license": "MIT",
  "type": "module",
  "nebutra": {
    "status": "wip",
    "productionReady": false,
    "surface": "ecosystem-product",
    "requires": [
      "@nebutra/content-store for profile and match artifacts",
      "@nebutra/event-log for match lifecycle checkpoints",
      "@nebutra/capability-kit for debug and doctor surfaces"
    ],
    "gaps": [
      "Encrypted chat transport is represented as a mutual-consent handoff",
      "Identity verification is represented as profile metadata until live providers are wired",
      "Reputation and abuse review remain deterministic local records"
    ],
    "featureId": "cofounder-match",
    "category": "ai",
    "summary": "Real-activity-based founder matching with explainable complementarity"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/capability-kit": "workspace:*",
    "@nebutra/content-store": "workspace:*",
    "@nebutra/errors": "workspace:*",
    "@nebutra/event-log": "workspace:*",
    "@nebutra/generation-context": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/ai/cofounder-match#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/ai/cofounder-match"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
