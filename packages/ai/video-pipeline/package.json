{
  "name": "@nebutra/video-pipeline",
  "version": "0.1.1",
  "description": "Storyboard-first video planning, rendering manifests, and cost previews",
  "private": false,
  "license": "MIT",
  "type": "module",
  "nebutra": {
    "status": "wip",
    "productionReady": false,
    "surface": "generation-capability",
    "requires": [
      "@nebutra/generation-context for BrandContext",
      "@nebutra/image-pipeline for visual asset inputs",
      "@nebutra/sandbox-runtime for video model and ffmpeg sidecars"
    ],
    "gaps": [
      "Model-backed clip rendering is adapter-gated",
      "FFmpeg composition is represented as a deterministic manifest until the sandbox sidecar is wired",
      "Remote provider quotas are health-checked through env only"
    ],
    "featureId": "video-pipeline",
    "category": "ai",
    "summary": "Storyboard-first brand video planning, cost, preview, and composition surface"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/capability-kit": "workspace:*",
    "@nebutra/errors": "workspace:*",
    "@nebutra/generation-context": "workspace:*",
    "@nebutra/image-pipeline": "workspace:*",
    "@nebutra/reel": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/ai/video-pipeline#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/ai/video-pipeline"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
