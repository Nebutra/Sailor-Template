{
  "name": "@nebutra/agent-runtime",
  "version": "0.2.1",
  "private": false,
  "license": "MIT",
  "type": "module",
  "nebutra": {
    "status": "wip",
    "productionReady": false,
    "requires": [
      "@nebutra/agents for model execution",
      "@nebutra/tenant for tenant scoping"
    ],
    "gaps": [
      "Track-B kernel sidecar transport not yet wired",
      "Durable-turn queue binding is interface-only",
      "Rollout store backed by in-memory reference impl only",
      "Pulsar facade is runnable but still delegates model execution through injected ports"
    ],
    "featureId": "agent-runtime",
    "category": "ai",
    "surface": "agent-runtime",
    "summary": "Multi-tenant agent-runtime grammar: thread/turn/item model, approval+capability policy, tool/MCP abstraction, event-sourced rollout, external-sandbox delegation seam"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./model": "./src/model.ts",
    "./protocol": "./src/protocol.ts",
    "./pulsar": "./src/pulsar.ts",
    "./orchestration": "./src/orchestration.ts",
    "./policy": "./src/policy.ts",
    "./tools": "./src/tools.ts",
    "./rollout": "./src/rollout.ts",
    "./sandbox": "./src/sandbox.ts",
    "./adapters": "./src/adapters/index.ts",
    "./adapters/mcp-catalog": "./src/adapters/mcp-catalog.ts",
    "./adapters/dispatcher-sse": "./src/adapters/dispatcher-sse.ts",
    "./adapters/prisma-rollout": "./src/adapters/prisma-rollout.ts"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/ai-primitives": "workspace:*",
    "@nebutra/capability-kit": "workspace:*",
    "@nebutra/execution-policy": "workspace:*",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@nebutra/mcp": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@nebutra/mcp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nebutra/mcp": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "^4.0.18"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/ai/agent-runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/ai/agent-runtime"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
