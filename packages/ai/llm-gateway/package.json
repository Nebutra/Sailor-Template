{
  "name": "@nebutra/llm-gateway",
  "version": "0.1.0",
  "description": "Capability-based LLM gateway with routing, fallback, prefix cache, and usage ledger",
  "private": false,
  "license": "MIT",
  "type": "module",
  "nebutra": {
    "status": "wip",
    "productionReady": false,
    "requires": [
      "@nebutra/provider-registry local-provider experiment"
    ],
    "gaps": [
      "Not wired to the production API gateway auth, tenant metering, or vault-backed key pool",
      "In-memory cache/debug/usage ledger only; no durable budget enforcement",
      "Superseded for production model execution by @nebutra/agents plus backends/gateway"
    ],
    "featureId": "llm-gateway",
    "category": "ai",
    "summary": "Routing, fallback, prefix prompt cache, and cost tracking over provider-registry"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/errors": "workspace:*",
    "@nebutra/provider-registry": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/ai/llm-gateway#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/ai/llm-gateway"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
