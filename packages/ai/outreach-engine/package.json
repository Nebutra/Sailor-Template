{
  "name": "@nebutra/outreach-engine",
  "version": "0.1.0",
  "description": "Compliance-first outreach campaign Play package for founder-led sales workflows",
  "private": false,
  "license": "MIT",
  "type": "module",
  "nebutra": {
    "status": "wip",
    "productionReady": false,
    "surface": "play-product",
    "requires": [
      "@nebutra/play-loader for SKILL.md play parsing",
      "@nebutra/generation-context for product voice",
      "@nebutra/content-store for campaign file truth",
      "@nebutra/event-log for campaign checkpoints"
    ],
    "gaps": [
      "Lead sourcing uses deterministic local planning until integration-vault lead providers are configured",
      "Send operations are draft-only until sender adapters and explicit approval are wired"
    ],
    "featureId": "outreach-engine",
    "category": "ai",
    "summary": "Compliance-first outreach Play product that produces auditable campaign drafts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/capability-kit": "workspace:*",
    "@nebutra/content-store": "workspace:*",
    "@nebutra/errors": "workspace:*",
    "@nebutra/event-log": "workspace:*",
    "@nebutra/generation-context": "workspace:*",
    "@nebutra/play-loader": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/ai/outreach-engine#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/ai/outreach-engine"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
