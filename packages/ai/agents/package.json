{
  "name": "@nebutra/agents",
  "version": "1.1.0",
  "description": "Nebutra AI runtime: multi-agent orchestration + Vercel AI SDK helpers (absorbed @nebutra/ai-sdk in 1.0.0)",
  "private": false,
  "license": "MIT",
  "type": "module",
  "nebutra": {
    "featureId": "agents",
    "category": "ai",
    "surface": "model-runtime",
    "summary": "Nebutra AI runtime: multi-agent orchestration + Vercel AI SDK helpers"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./tools": "./src/tools.ts",
    "./providers/vercel-ai": "./src/providers/vercel-ai.ts",
    "./providers/langchain": "./src/providers/langchain.ts",
    "./generation": "./src/generation/index.ts",
    "./sdk": "./src/sdk/index.ts",
    "./sdk/config": "./src/sdk/config.ts",
    "./sdk/models": "./src/sdk/models.ts",
    "./sdk/provider": "./src/sdk/provider.ts",
    "./env": "./src/env.ts",
    "./observability": "./src/observability.ts",
    "./fallback": "./src/fallback.ts"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
