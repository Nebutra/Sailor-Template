{
  "name": "@nebutra/document-pipeline",
  "version": "0.1.0",
  "description": "Document parse, chunk, embed-port, and content-store ingestion pipeline",
  "private": false,
  "license": "MIT",
  "type": "module",
  "nebutra": {
    "status": "wip",
    "productionReady": false,
    "surface": "execution-capability",
    "requires": [
      "@nebutra/content-store for file-truth indexing",
      "@nebutra/sandbox-runtime for parser sidecars"
    ],
    "gaps": [
      "Complex PDF, office, and OCR parsing require a configured parser sidecar",
      "Embedding is delegated to content-store/model ports rather than owned here",
      "Async ingestion jobs are not yet backed by a durable queue"
    ],
    "featureId": "document-pipeline",
    "category": "ai",
    "summary": "Parser router, metadata-preserving chunks, content-store ingest, doctor, and debug tools"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/capability-kit": "workspace:*",
    "@nebutra/content-store": "workspace:*",
    "@nebutra/errors": "workspace:*",
    "@nebutra/sandbox-runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/ai/document-pipeline#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/ai/document-pipeline"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
