{
  "name": "@nebutra/brand-genesis",
  "version": "0.2.1",
  "description": "BrandContext-first flagship play for creating a complete brand package from one idea",
  "private": false,
  "license": "MIT",
  "type": "module",
  "nebutra": {
    "status": "wip",
    "productionReady": false,
    "surface": "play-product",
    "requires": [
      "@nebutra/play-loader for SKILL.md play parsing",
      "@nebutra/generation-context for BrandContext",
      "@nebutra/content-store for BrandContext materialization",
      "@nebutra/image-pipeline, @nebutra/video-pipeline, @nebutra/audio-pipeline, @nebutra/voice-realtime, and @nebutra/3d-pipeline for generated assets",
      "@nebutra/event-log for Time Machine checkpoints"
    ],
    "gaps": [
      "Generated media uses deterministic local fallbacks until model-backed providers are configured",
      "Storyboard editing is represented as an orchestration checkpoint, not yet a GUI step",
      "Landing page handoff is minimal inside Brand Genesis; @nebutra/landing-builder owns the standalone site Play"
    ],
    "featureId": "brand-genesis",
    "category": "ai",
    "summary": "Flagship play that distills an idea into BrandContext and orchestrates lower generation capabilities"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/3d-pipeline": "workspace:*",
    "@nebutra/audio-pipeline": "workspace:*",
    "@nebutra/capability-kit": "workspace:*",
    "@nebutra/content-store": "workspace:*",
    "@nebutra/errors": "workspace:*",
    "@nebutra/event-log": "workspace:*",
    "@nebutra/generation-context": "workspace:*",
    "@nebutra/image-pipeline": "workspace:*",
    "@nebutra/play-loader": "workspace:*",
    "@nebutra/video-pipeline": "workspace:*",
    "@nebutra/voice-realtime": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/ai/brand-genesis#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/ai/brand-genesis"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
