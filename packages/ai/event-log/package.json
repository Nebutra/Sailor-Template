{
  "name": "@nebutra/event-log",
  "version": "0.1.0",
  "description": "Append-only event log with content-addressed snapshots",
  "private": false,
  "license": "MIT",
  "type": "module",
  "nebutra": {
    "featureId": "event-log",
    "category": "ai",
    "summary": "Immutable event log, rollback dry-runs, and branches"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/content-store": "workspace:*",
    "@nebutra/errors": "workspace:*",
    "@noble/hashes": "2.0.1"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/ai/event-log#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/ai/event-log"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
