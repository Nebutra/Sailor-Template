{
  "name": "@nebutra/metering",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "nebutra": {
    "status": "foundation",
    "productionReady": false,
    "requires": [
      "CLICKHOUSE_URL or in-memory provider for dev"
    ],
    "gaps": [
      "ClickHouse provider is a stub — needs real client integration",
      "Quota enforcement helper exists for billing-style limits, but consuming billing/API middleware wiring is pending",
      "Aggregation rollups pending"
    ]
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./clickhouse": "./src/providers/clickhouse.ts",
    "./memory": "./src/providers/memory.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/logger": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
