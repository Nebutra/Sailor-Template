{
  "name": "@nebutra/webhooks",
  "version": "0.1.0",
  "private": false,
  "license": "AGPL-3.0",
  "type": "module",
  "nebutra": {
    "status": "foundation",
    "productionReady": false,
    "requires": [
      "SVIX_API_TOKEN (managed)",
      "or WEBHOOK_SIGNING_SECRET for custom self-hosted delivery"
    ],
    "gaps": [
      "Custom delivery adapter exposes an injectable dead-letter store seam; bundled default remains in-memory",
      "Endpoint management UI not scaffolded",
      "Replay protection helpers are available; production use should inject a durable replay store"
    ]
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./svix": {
      "types": "./dist/providers/svix.d.ts",
      "import": "./dist/providers/svix.js"
    },
    "./custom": {
      "types": "./dist/providers/custom.d.ts",
      "import": "./dist/providers/custom.js"
    },
    "./signing": {
      "types": "./dist/signing.d.ts",
      "import": "./dist/signing.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/logger": "workspace:*",
    "svix": "^1.42.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/integrations/webhooks#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/integrations/webhooks"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
