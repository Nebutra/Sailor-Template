{
  "name": "@nebutra/webhooks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "nebutra": {
    "status": "foundation",
    "productionReady": false,
    "requires": [
      "SVIX_API_TOKEN (managed)",
      "or WEBHOOK_SIGNING_SECRET for custom self-hosted delivery"
    ],
    "gaps": [
      "Custom delivery adapter has in-memory retry + dead-letter metadata but lacks durable persistence",
      "Endpoint management UI not scaffolded",
      "Replay protection helpers incomplete"
    ]
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./svix": "./src/providers/svix.ts",
    "./custom": "./src/providers/custom.ts",
    "./signing": "./src/signing.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/logger": "workspace:*",
    "svix": "^1.42.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
