{
  "name": "@nebutra/queue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "nebutra": {
    "status": "foundation",
    "productionReady": false,
    "requires": [
      "QSTASH_TOKEN (+ signing keys) for serverless",
      "REDIS_URL for BullMQ self-hosted",
      "AWS_SQS_QUEUE_URL (+ AWS credentials) for SQS"
    ],
    "gaps": [
      "QStash provider dead letter retrieval not implemented",
      "Worker auto-scaling TODO"
    ]
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./qstash": "./src/providers/qstash.ts",
    "./bullmq": "./src/providers/bullmq.ts",
    "./sqs": "./src/providers/sqs.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.700.0",
    "@nebutra/db": "workspace:*",
    "@nebutra/logger": "workspace:*",
    "@upstash/qstash": "^2.7.17",
    "bullmq": "^5.34.8",
    "ioredis": "^5.4.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
}
