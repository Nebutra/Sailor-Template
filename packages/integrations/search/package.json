{
  "name": "@nebutra/search",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "nebutra": {
    "status": "foundation",
    "productionReady": false,
    "requires": [
      "MEILISEARCH_URL + MEILISEARCH_MASTER_KEY",
      "or TYPESENSE_HOST + TYPESENSE_API_KEY",
      "or ALGOLIA_APP_ID + ALGOLIA_ADMIN_API_KEY",
      "or DATABASE_URL (Postgres + pgvector extension)"
    ],
    "gaps": [
      "Provider adapters are stubs — need bulk index + faceted search",
      "Tenant-scoped index isolation not enforced"
    ]
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./meilisearch": "./src/providers/meilisearch.ts",
    "./typesense": "./src/providers/typesense.ts",
    "./algolia": "./src/providers/algolia.ts",
    "./pgvector": "./src/providers/pgvector.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/logger": "workspace:*",
    "meilisearch": "^0.44.1",
    "typesense": "^2.0.0",
    "algoliasearch": "^5.20.0",
    "pg": "^8.13.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "typescript": "catalog:"
  }
}
