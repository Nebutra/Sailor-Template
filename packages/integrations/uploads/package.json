{
  "name": "@nebutra/uploads",
  "version": "0.1.0",
  "private": false,
  "license": "AGPL-3.0-only",
  "type": "module",
  "nebutra": {
    "status": "foundation",
    "productionReady": false,
    "requires": [
      "AWS_S3_BUCKET + AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY (or R2 equivalents)",
      "or local filesystem for dev"
    ],
    "gaps": [
      "Tus resumable adapter optional-peer, not wired end-to-end",
      "Virus-scan hook pending"
    ],
    "featureId": "uploads",
    "category": "integrations",
    "summary": "Large file uploads — S3/R2 multipart + Tus resumable + presigned URLs"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./s3": {
      "types": "./dist/providers/s3.d.ts",
      "import": "./dist/providers/s3.js"
    },
    "./local": {
      "types": "./dist/providers/local.d.ts",
      "import": "./dist/providers/local.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@nebutra/logger": "workspace:*",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@vercel/blob": ">=0.23.0",
    "tus-js-client": "^4.2.0"
  },
  "peerDependenciesMeta": {
    "@vercel/blob": {
      "optional": true
    },
    "tus-js-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/integrations/uploads#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/integrations/uploads"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
