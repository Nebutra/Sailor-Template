{
  "name": "@nebutra/email",
  "version": "0.1.1",
  "description": "Multi-provider transactional email (Resend, Nodemailer, Console)",
  "private": false,
  "license": "MIT",
  "type": "module",
  "nebutra": {
    "featureId": "email",
    "category": "integrations",
    "summary": "Multi-provider transactional email (Resend, Nodemailer, Console)"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "resend": "^4.0.1"
  },
  "peerDependencies": {
    "nodemailer": "^8.0.7"
  },
  "peerDependenciesMeta": {
    "nodemailer": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/integrations/email#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/integrations/email"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
