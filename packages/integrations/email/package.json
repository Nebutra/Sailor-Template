{
  "name": "@nebutra/email",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-provider transactional email (Resend, Nodemailer, Console)",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "resend": "^4.0.1"
  },
  "peerDependencies": {
    "nodemailer": "^6.9.0"
  },
  "peerDependenciesMeta": {
    "nodemailer": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "nebutra": {
    "featureId": "email",
    "category": "integrations",
    "summary": "Multi-provider transactional email (Resend, Nodemailer, Console)"
  }
}
