{
  "name": "@nebutra/admin-tooling",
  "version": "0.1.1",
  "private": true,
  "description": "Thin contract layer for external admin tools (Retool, Forest Admin, Appsmith) to safely access internal Nebutra-Sailor data with audit trails",
  "type": "module",
  "nebutra": {
    "status": "foundation",
    "productionReady": false,
    "requires": [
      "Optional: @nebutra/audit for automatic audit trail",
      "Optional: read-only Postgres replica via READONLY_DATABASE_URL"
    ],
    "gaps": [
      "No concrete Retool/Forest/Appsmith adapter examples wired up",
      "No integration tests yet",
      "Not yet adopted by apps/web admin surface"
    ]
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./contract": "./src/contract.ts",
    "./audit-hook": "./src/audit-hook.ts",
    "./readonly-db": "./src/readonly-db.ts"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/logger": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "catalog:",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "@nebutra/audit": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@nebutra/audit": {
      "optional": true
    }
  },
  "license": "AGPL-3.0-only"
}
