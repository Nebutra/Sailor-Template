{
  "name": "@nebutra/notifications",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "nebutra": {
    "status": "foundation",
    "productionReady": false,
    "requires": [
      "NOVU_API_KEY (managed)",
      "or direct dispatchers plus durable preference and in-app stores"
    ],
    "gaps": [
      "Novu provider adapter stubs — no batching, retries limited",
      "Direct production mode requires injected durable preference and in-app stores",
      "Provider health and retry telemetry are still minimal"
    ]
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./novu": "./src/providers/novu.ts",
    "./knock": "./src/providers/knock.ts",
    "./direct": "./src/providers/direct.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/logger": "workspace:*",
    "@novu/node": "^2.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
