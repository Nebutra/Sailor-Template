{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "incremental": false,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2022",
    "types": ["node"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["scripts/**/*.ts", "style-dictionary.config.mjs", "tokens/**/*.json"],
  "exclude": ["build", "node_modules"]
}
