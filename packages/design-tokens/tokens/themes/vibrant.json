{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Vibrant — Creative UI/UX. Orange primary + Space Grotesk + extra-rounded radii. Mirrors [data-theme=vibrant].",
  "theme": "vibrant",
  "color": {
    "primary": { "$value": "oklch(0.705 0.213 47.6)", "$type": "color" },
    "primary-foreground": { "$value": "oklch(1 0 0)", "$type": "color" },
    "secondary": { "$value": "oklch(0.769 0.189 70.1)", "$type": "color" },
    "secondary-foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "accent": { "$value": "oklch(0.645 0.246 16.4)", "$type": "color" },
    "accent-foreground": { "$value": "oklch(1 0 0)", "$type": "color" },
    "background": { "$value": "oklch(0.991 0.015 95.3)", "$type": "color" },
    "foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "card": { "$value": "oklch(1 0 0)", "$type": "color" },
    "card-foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "popover": { "$value": "oklch(1 0 0)", "$type": "color" },
    "popover-foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "muted": { "$value": "oklch(0.967 0.012 90)", "$type": "color" },
    "muted-foreground": { "$value": "oklch(0.552 0.016 286)", "$type": "color" },
    "border": { "$value": "oklch(0.922 0.008 80)", "$type": "color" },
    "input": { "$value": "oklch(0.922 0.008 80)", "$type": "color" },
    "ring": { "$value": "oklch(0.705 0.213 47.6)", "$type": "color" },
    "primary-hover": {
      "$value": "color-mix(in oklch, oklch(0.705 0.213 47.6), black 10%)",
      "$type": "color"
    },
    "primary-active": {
      "$value": "color-mix(in oklch, oklch(0.705 0.213 47.6), black 20%)",
      "$type": "color"
    }
  },
  "radius": {
    "sm": { "$value": "0.75rem", "$type": "dimension" },
    "md": { "$value": "1rem", "$type": "dimension" },
    "lg": { "$value": "1.5rem", "$type": "dimension" },
    "xl": { "$value": "9999px", "$type": "dimension" }
  },
  "fontFamily": {
    "sans": {
      "$value": "\"Space Grotesk\", ui-sans-serif, system-ui, sans-serif",
      "$type": "fontFamily"
    },
    "heading": {
      "$value": "\"Space Grotesk\", ui-sans-serif, system-ui, sans-serif",
      "$type": "fontFamily"
    }
  },
  "shadow": {
    "sm": { "$value": "0 1px 3px 0 rgb(249 115 22 / 0.1)", "$type": "shadow" },
    "md": { "$value": "0 4px 6px -1px rgb(249 115 22 / 0.15)", "$type": "shadow" },
    "lg": { "$value": "0 10px 15px -3px rgb(249 115 22 / 0.15)", "$type": "shadow" },
    "xl": { "$value": "0 20px 25px -5px rgb(249 115 22 / 0.15)", "$type": "shadow" }
  }
}
