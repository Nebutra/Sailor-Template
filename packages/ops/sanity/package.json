{
  "name": "@nebutra/sanity",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./queries": {
      "types": "./dist/queries.d.ts",
      "import": "./dist/queries.js"
    },
    "./image": {
      "types": "./dist/image.d.ts",
      "import": "./dist/image.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sanity/client": "^7.16.0",
    "@sanity/image-url": "^2.0.3"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "catalog:"
  }
}
