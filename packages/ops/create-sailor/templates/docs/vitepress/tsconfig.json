{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "types": ["vitepress/client"]
  },
  "include": [".vitepress/**/*.ts", "**/*.md"],
  "exclude": ["node_modules", ".vitepress/dist", ".vitepress/cache"]
}
