{
  "$schema": "https://nebutra.com/schemas/theme-registry.json",
  "version": "2026.05",
  "defaultTheme": "neon",
  "themes": [
    {
      "id": "neon",
      "name": "Neon",
      "category": "ai-native",
      "mood": "AI SaaS default - dark, electric, high contrast",
      "tokenPath": "tokens/themes/neon.json",
      "install": {
        "command": "nebutra theme add neon",
        "registryUrl": "https://ui.nebutra.com/themes/neon.json"
      },
      "compatibility": {
        "tailwind": "4",
        "cssVariables": true,
        "figmaVariables": true,
        "shadcnRegistry": true
      },
      "governance": {
        "wcag": "AA",
        "requiredTokens": [
          "color.primary",
          "color.primary-foreground",
          "color.background",
          "color.foreground",
          "color.card",
          "color.border",
          "color.ring",
          "radius.md",
          "fontFamily.sans"
        ],
        "visualSuites": ["forms", "pricing", "dashboard", "ai-chat", "charts"]
      }
    },
