{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Gradient — Marketing/Growth theme. Light surface + brand-blue primary. Mirrors [data-theme=gradient].",
  "theme": "gradient",
  "color": {
    "primary": { "$value": "oklch(0.546 0.245 262.9)", "$type": "color" },
    "primary-foreground": { "$value": "oklch(1 0 0)", "$type": "color" },
    "secondary": { "$value": "oklch(0.707 0.165 254.6)", "$type": "color" },
    "secondary-foreground": { "$value": "oklch(1 0 0)", "$type": "color" },
    "accent": { "$value": "oklch(0.623 0.214 259.1)", "$type": "color" },
    "accent-foreground": { "$value": "oklch(1 0 0)", "$type": "color" },
    "background": { "$value": "oklch(1 0 0)", "$type": "color" },
    "foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "card": { "$value": "oklch(0.985 0 0)", "$type": "color" },
    "card-foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "popover": { "$value": "oklch(1 0 0)", "$type": "color" },
    "popover-foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "muted": { "$value": "oklch(0.967 0.001 286)", "$type": "color" },
    "muted-foreground": { "$value": "oklch(0.552 0.016 286)", "$type": "color" },
    "border": { "$value": "oklch(0.922 0.004 286)", "$type": "color" },
    "input": { "$value": "oklch(0.922 0.004 286)", "$type": "color" },
    "ring": { "$value": "oklch(0.546 0.245 262.9)", "$type": "color" },
    "primary-hover": {
      "$value": "color-mix(in oklch, oklch(0.546 0.245 262.9), black 10%)",
      "$type": "color"
    },
    "primary-active": {
      "$value": "color-mix(in oklch, oklch(0.546 0.245 262.9), black 20%)",
      "$type": "color"
    }
  },
  "radius": {
    "sm": { "$value": "0.375rem", "$type": "dimension" },
    "md": { "$value": "0.5rem", "$type": "dimension" },
    "lg": { "$value": "0.75rem", "$type": "dimension" },
    "xl": { "$value": "1rem", "$type": "dimension" }
  },
  "shadow": {
    "sm": { "$value": "0 1px 2px 0 rgb(0 0 0 / 0.05)", "$type": "shadow" },
    "md": { "$value": "0 4px 6px -1px rgb(0 0 0 / 0.1)", "$type": "shadow" },
    "lg": { "$value": "0 10px 15px -3px rgb(0 0 0 / 0.1)", "$type": "shadow" },
    "xl": { "$value": "0 20px 25px -5px rgb(0 0 0 / 0.1)", "$type": "shadow" }
  }
}
