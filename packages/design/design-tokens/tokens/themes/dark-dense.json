{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Dark-dense — DevOps Dashboard. Compact radii, monospace font, green primary. Mirrors [data-theme=dark-dense].",
  "theme": "dark-dense",
  "color": {
    "primary": { "$value": "oklch(0.696 0.17 162.5)", "$type": "color" },
    "primary-foreground": { "$value": "oklch(1 0 0)", "$type": "color" },
    "secondary": { "$value": "oklch(0.527 0.154 163.2)", "$type": "color" },
    "secondary-foreground": { "$value": "oklch(1 0 0)", "$type": "color" },
    "accent": { "$value": "oklch(0.765 0.163 163.4)", "$type": "color" },
    "accent-foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "background": { "$value": "oklch(0.112 0 0)", "$type": "color" },
    "foreground": { "$value": "oklch(0.985 0 0)", "$type": "color" },
    "card": { "$value": "oklch(0.162 0.004 285.9)", "$type": "color" },
    "card-foreground": { "$value": "oklch(0.985 0 0)", "$type": "color" },
    "popover": { "$value": "oklch(0.162 0.004 285.9)", "$type": "color" },
    "popover-foreground": { "$value": "oklch(0.985 0 0)", "$type": "color" },
    "muted": { "$value": "oklch(0.215 0.006 285.9)", "$type": "color" },
    "muted-foreground": { "$value": "oklch(0.705 0.015 286)", "$type": "color" },
    "border": { "$value": "oklch(0.215 0.006 285.9)", "$type": "color" },
    "input": { "$value": "oklch(0.215 0.006 285.9)", "$type": "color" },
    "ring": { "$value": "oklch(0.696 0.17 162.5)", "$type": "color" },
    "primary-hover": {
      "$value": "color-mix(in oklch, oklch(0.696 0.17 162.5), white 15%)",
      "$type": "color"
    },
    "primary-active": {
      "$value": "color-mix(in oklch, oklch(0.696 0.17 162.5), black 10%)",
      "$type": "color"
    }
  },
  "radius": {
    "sm": { "$value": "0.125rem", "$type": "dimension" },
    "md": { "$value": "0.25rem", "$type": "dimension" },
    "lg": { "$value": "0.25rem", "$type": "dimension" },
    "xl": { "$value": "0.375rem", "$type": "dimension" }
  },
  "fontFamily": {
    "sans": {
      "$value": "\"JetBrains Mono\", \"Fira Code\", ui-monospace, monospace",
      "$type": "fontFamily"
    },
    "heading": {
      "$value": "\"JetBrains Mono\", \"Fira Code\", ui-monospace, monospace",
      "$type": "fontFamily"
    }
  }
}
