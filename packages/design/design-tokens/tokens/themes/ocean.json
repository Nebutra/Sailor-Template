{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Ocean — Community theme. Cyan-sea palette on tinted background. Mirrors [data-theme=ocean].",
  "theme": "ocean",
  "color": {
    "primary": { "$value": "oklch(0.609 0.126 199.8)", "$type": "color" },
    "primary-foreground": { "$value": "oklch(1 0 0)", "$type": "color" },
    "secondary": { "$value": "oklch(0.715 0.143 215.2)", "$type": "color" },
    "secondary-foreground": { "$value": "oklch(1 0 0)", "$type": "color" },
    "accent": { "$value": "oklch(0.777 0.152 181.9)", "$type": "color" },
    "accent-foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "background": { "$value": "oklch(0.982 0.018 180.7)", "$type": "color" },
    "foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "card": { "$value": "oklch(1 0 0)", "$type": "color" },
    "card-foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "popover": { "$value": "oklch(1 0 0)", "$type": "color" },
    "popover-foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "muted": { "$value": "oklch(0.953 0.024 184)", "$type": "color" },
    "muted-foreground": { "$value": "oklch(0.442 0.017 285.9)", "$type": "color" },
    "border": { "$value": "oklch(0.905 0.032 185)", "$type": "color" },
    "input": { "$value": "oklch(0.905 0.032 185)", "$type": "color" },
    "ring": { "$value": "oklch(0.609 0.126 199.8)", "$type": "color" },
    "primary-hover": {
      "$value": "color-mix(in oklch, oklch(0.609 0.126 199.8), black 10%)",
      "$type": "color"
    },
    "primary-active": {
      "$value": "color-mix(in oklch, oklch(0.609 0.126 199.8), black 20%)",
      "$type": "color"
    }
  },
  "radius": {
    "sm": { "$value": "0.375rem", "$type": "dimension" },
    "md": { "$value": "0.5rem", "$type": "dimension" },
    "lg": { "$value": "0.75rem", "$type": "dimension" },
    "xl": { "$value": "1rem", "$type": "dimension" }
  },
  "fontFamily": {
    "sans": { "$value": "\"Inter\", ui-sans-serif, system-ui, sans-serif", "$type": "fontFamily" }
  },
  "shadow": {
    "sm": { "$value": "0 1px 2px 0 rgb(8 145 178 / 0.08)", "$type": "shadow" },
    "md": { "$value": "0 4px 6px -1px rgb(8 145 178 / 0.12)", "$type": "shadow" },
    "lg": { "$value": "0 10px 15px -3px rgb(8 145 178 / 0.12)", "$type": "shadow" },
    "xl": { "$value": "0 20px 25px -5px rgb(8 145 178 / 0.12)", "$type": "shadow" }
  }
}
