{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Dark mode theme — 12-step scales inverted (1=darkest, 12=lightest) + shadcn HSL semantics + dark-mode brand alias overrides. Mirrors .dark in @nebutra/tokens/styles.css.",
  "brand": {
    "$description": "Dark-mode brand alias overrides. In dark mode the visible brand fills shift to lighter steps for AA contrast on dark surfaces.",
    "primary": {
      "$value": "{color.nebutra-blue.400}",
      "$type": "color",
      "$description": "Dark-mode brand primary — visible against dark surfaces (uses --blue-9 = nebutra-blue-400)."
    },
    "accent": {
      "$value": "{color.nebutra-cyan.400}",
      "$type": "color",
      "$description": "Dark-mode brand accent — visible against dark surfaces (uses --cyan-9 = nebutra-cyan-400)."
    }
  },
  "status": {
    "info": {
      "$value": "{color.nebutra-blue.400}",
      "$type": "color",
      "$description": "Dark-mode info color — equals dark brand-primary."
    }
  },
  "ring": {
    "hairline": {
      "$value": "inset 0 0 0 1px rgb(255 255 255 / 0.06)",
      "$type": "string",
      "$description": "Hairline override — more visible on dark background"
    }
  },
  "overlay": {
    "faint": {
      "$value": "rgb(255 255 255 / 0.06)",
      "$type": "color",
      "$description": "Dark-mode faint overlay (6% white) — inverted from light"
    }
  },
  "scale": {
    "neutral": {
      "1": { "$value": "{color.nebutra-neutral.950}", "$type": "color" },
      "2": { "$value": "{color.nebutra-neutral.900}", "$type": "color" },
      "3": { "$value": "{color.nebutra-neutral.800}", "$type": "color" },
      "4": { "$value": "{color.nebutra-neutral.700}", "$type": "color" },
      "5": { "$value": "{color.nebutra-neutral.600}", "$type": "color" },
      "6": { "$value": "{color.nebutra-gray.900}", "$type": "color" },
      "7": { "$value": "{color.nebutra-gray.800}", "$type": "color" },
      "8": { "$value": "{color.nebutra-gray.700}", "$type": "color" },
      "9": { "$value": "{color.nebutra-neutral.400}", "$type": "color" },
      "10": { "$value": "{color.nebutra-neutral.300}", "$type": "color" },
      "11": { "$value": "{color.nebutra-neutral.200}", "$type": "color" },
      "12": { "$value": "{color.nebutra-neutral.50}", "$type": "color" }
    },
    "blue": {
      "1": { "$value": "{color.nebutra-blue.950}", "$type": "color" },
      "2": { "$value": "{color.nebutra-blue.900}", "$type": "color" },
      "3": { "$value": "{color.nebutra-blue.800}", "$type": "color" },
      "4": { "$value": "{color.nebutra-blue.700}", "$type": "color" },
      "5": { "$value": "{color.nebutra-blue.600}", "$type": "color" },
      "6": { "$value": "{color.nebutra-blue.800}", "$type": "color" },
      "7": { "$value": "{color.nebutra-blue.700}", "$type": "color" },
      "8": { "$value": "{color.nebutra-blue.600}", "$type": "color" },
      "9": { "$value": "{color.nebutra-blue.400}", "$type": "color" },
      "10": { "$value": "{color.nebutra-blue.300}", "$type": "color" },
      "11": { "$value": "{color.nebutra-blue.200}", "$type": "color" },
      "12": { "$value": "{color.nebutra-blue.100}", "$type": "color" }
    },
    "cyan": {
      "1": { "$value": "{color.nebutra-cyan.950}", "$type": "color" },
      "2": { "$value": "{color.nebutra-cyan.900}", "$type": "color" },
      "3": { "$value": "{color.nebutra-cyan.800}", "$type": "color" },
      "4": { "$value": "{color.nebutra-cyan.700}", "$type": "color" },
      "5": { "$value": "{color.nebutra-cyan.600}", "$type": "color" },
      "6": { "$value": "{color.nebutra-cyan.800}", "$type": "color" },
      "7": { "$value": "{color.nebutra-cyan.700}", "$type": "color" },
      "8": { "$value": "{color.nebutra-cyan.600}", "$type": "color" },
      "9": { "$value": "{color.nebutra-cyan.400}", "$type": "color" },
      "10": { "$value": "{color.nebutra-cyan.300}", "$type": "color" },
      "11": { "$value": "{color.nebutra-cyan.200}", "$type": "color" },
      "12": { "$value": "{color.nebutra-cyan.100}", "$type": "color" }
    }
  },
  "shadcn": {
    "background": { "$value": "222 47% 4%", "$type": "string" },
    "foreground": { "$value": "210 40% 98%", "$type": "string" },
    "card": { "$value": "222 47% 7%", "$type": "string" },
    "card-foreground": { "$value": "210 40% 98%", "$type": "string" },
    "popover": { "$value": "222 47% 7%", "$type": "string" },
    "popover-foreground": { "$value": "210 40% 98%", "$type": "string" },
    "primary": { "$value": "228 90% 72%", "$type": "string" },
    "primary-foreground": { "$value": "222 47% 4%", "$type": "string" },
    "secondary": { "$value": "217 33% 17%", "$type": "string" },
    "secondary-foreground": { "$value": "210 40% 98%", "$type": "string" },
    "muted": { "$value": "217 33% 17%", "$type": "string" },
    "muted-foreground": { "$value": "215 20% 65%", "$type": "string" },
    "accent": { "$value": "228 100% 12%", "$type": "string" },
    "accent-foreground": { "$value": "228 95% 67%", "$type": "string" },
    "destructive": { "$value": "0 63% 31%", "$type": "string" },
    "destructive-foreground": { "$value": "210 40% 98%", "$type": "string" },
    "success": { "$value": "142 76% 36%", "$type": "string" },
    "success-foreground": { "$value": "222 47% 4%", "$type": "string" },
    "warning": { "$value": "38 80% 45%", "$type": "string" },
    "warning-foreground": { "$value": "222 47% 4%", "$type": "string" },
    "info": { "$value": "228 95% 67%", "$type": "string" },
    "info-foreground": { "$value": "222 47% 4%", "$type": "string" },
    "border": { "$value": "0 0% 14.9%", "$type": "string" },
    "input": { "$value": "0 0% 14.9%", "$type": "string" },
    "ring": {
      "$value": "0 0% 88%",
      "$type": "string",
      "$description": "Focus ring (dark mode) — neutral light gray. Mirrors light-mode neutral foreground choice."
    },
    "sidebar": { "$value": "222 47% 6%", "$type": "string" },
    "sidebar-foreground": { "$value": "210 40% 96%", "$type": "string" },
    "sidebar-primary": { "$value": "228 95% 67%", "$type": "string" },
    "sidebar-primary-foreground": { "$value": "222 47% 4%", "$type": "string" },
    "sidebar-accent": { "$value": "228 100% 12%", "$type": "string" },
    "sidebar-accent-foreground": { "$value": "228 95% 67%", "$type": "string" },
    "sidebar-border": { "$value": "0 0% 14.9%", "$type": "string" },
    "sidebar-ring": { "$value": "228 95% 67%", "$type": "string" },
    "chart-1": { "$value": "228 95% 67%", "$type": "string" },
    "chart-2": { "$value": "168 96% 54%", "$type": "string" },
    "chart-3": { "$value": "228 100% 82%", "$type": "string" },
    "chart-4": { "$value": "168 100% 75%", "$type": "string" },
    "chart-5": { "$value": "228 100% 50%", "$type": "string" }
  },
  "ds": {
    "blue-200": { "$value": "oklch(25.45% 0.0811 255.8)", "$type": "color" },
    "blue-700": { "$value": "oklch(57.61% 0.2321 258.23)", "$type": "color" },
    "blue-900": { "$value": "oklch(71.7% 0.1648 250.79360374054167)", "$type": "color" },
    "red-200": { "$value": "oklch(25.93% 0.0834 19.02)", "$type": "color" },
    "red-700": { "$value": "oklch(62.56% 0.2234 23.03)", "$type": "color" },
    "red-900": { "$value": "oklch(69.96% 0.2136 22.03)", "$type": "color" },
    "amber-200": { "$value": "oklch(24.95% 0.0642 64.78)", "$type": "color" },
    "amber-700": { "$value": "oklch(81.87% 0.1969 76.46)", "$type": "color" },
    "amber-900": { "$value": "oklch(77.21% 0.1991 64.28)", "$type": "color" },
    "green-200": { "$value": "oklch(27.12% 0.0895 150.09)", "$type": "color" },
    "green-700": { "$value": "oklch(64.58% 0.199 147.27)", "$type": "color" },
    "green-900": { "$value": "oklch(73.1% 0.2158 148.29)", "$type": "color" },
    "teal-300": { "$value": "oklch(31.5% 0.0767 180.99)", "$type": "color" },
    "teal-700": { "$value": "oklch(64.92% 0.1403 181.95)", "$type": "color" },
    "teal-900": { "$value": "oklch(74.56% 0.1765 182.8)", "$type": "color" },
    "purple-200": { "$value": "oklch(25.91% 0.0921 314.41)", "$type": "color" },
    "purple-700": { "$value": "oklch(55.5% 0.2186 306.12)", "$type": "color" },
    "purple-900": { "$value": "oklch(69.87% 0.2037 309.51)", "$type": "color" },
    "pink-300": { "$value": "oklch(31.15% 0.1067 355.93)", "$type": "color" },
    "pink-700": { "$value": "oklch(63.52% 0.2346 1.01)", "$type": "color" },
    "pink-900": { "$value": "oklch(69.36% 0.2223 3.91)", "$type": "color" },
    "gray-100": {
      "$value": "hsla(0, 0%, 10%, 1)",
      "$type": "color",
      "$extensions": { "com.nebutra.oklch": "oklch(0.232 0 0)" }
    },
    "gray-200": {
      "$value": "hsla(0, 0%, 12%, 1)",
      "$type": "color",
      "$extensions": { "com.nebutra.oklch": "oklch(0.259 0 0)" }
    },
    "gray-500": {
      "$value": "hsla(0, 0%, 27%, 1)",
      "$type": "color",
      "$extensions": { "com.nebutra.oklch": "oklch(0.409 0 0)" }
    },
    "gray-600": {
      "$value": "hsla(0, 0%, 53%, 1)",
      "$type": "color",
      "$extensions": { "com.nebutra.oklch": "oklch(0.59 0 0)" }
    },
    "gray-700": {
      "$value": "hsla(0, 0%, 56%, 1)",
      "$type": "color",
      "$extensions": { "com.nebutra.oklch": "oklch(0.598 0 0)" }
    },
    "gray-1000": {
      "$value": "hsla(0, 0%, 93%, 1)",
      "$type": "color",
      "$extensions": { "com.nebutra.oklch": "oklch(0.94 0 0)" }
    },
    "background-100": {
      "$value": "hsla(0, 0%, 4%, 1)",
      "$type": "color",
      "$extensions": { "com.nebutra.oklch": "oklch(0.143 0 0)" }
    },
    "trial-start": { "$value": "rgb(0, 112, 243)", "$type": "color" },
    "trial-end": { "$value": "rgb(248, 28, 229)", "$type": "color" },
    "turbo-start": { "$value": "#ff1e56", "$type": "color" },
    "turbo-end": { "$value": "#0096ff", "$type": "color" }
  },
  "elevation": {
    "xs": { "$value": "0 1px 2px 0 rgb(0 0 0 / 0.3)", "$type": "shadow" },
    "sm": {
      "$value": "0 1px 3px 0 rgb(0 0 0 / 0.4), 0 1px 2px -1px rgb(0 0 0 / 0.4)",
      "$type": "shadow"
    },
    "md": {
      "$value": "0 4px 6px -1px rgb(0 0 0 / 0.4), 0 2px 4px -2px rgb(0 0 0 / 0.4)",
      "$type": "shadow"
    },
    "lg": {
      "$value": "0 10px 15px -3px rgb(0 0 0 / 0.5), 0 4px 6px -4px rgb(0 0 0 / 0.5)",
      "$type": "shadow"
    },
    "xl": {
      "$value": "0 20px 25px -5px rgb(0 0 0 / 0.6), 0 8px 10px -6px rgb(0 0 0 / 0.6)",
      "$type": "shadow"
    },
    "2xl": { "$value": "0 25px 50px -12px rgb(0 0 0 / 0.8)", "$type": "shadow" },
    "brand": {
      "$value": "0 0 0 1px rgb(92 124 250 / 0.25), 0 4px 20px -2px rgb(92 124 250 / 0.3)",
      "$type": "shadow"
    },
    "brand-lg": {
      "$value": "0 0 0 1px rgb(92 124 250 / 0.3), 0 8px 40px -4px rgb(92 124 250 / 0.4)",
      "$type": "shadow"
    }
  }
}
