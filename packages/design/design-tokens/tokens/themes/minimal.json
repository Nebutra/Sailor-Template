{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Minimal — Blog/Portfolio. Near-black primary, serif heading. Mirrors [data-theme=minimal].",
  "theme": "minimal",
  "color": {
    "primary": { "$value": "oklch(0.21 0.006 285.9)", "$type": "color" },
    "primary-foreground": { "$value": "oklch(1 0 0)", "$type": "color" },
    "secondary": { "$value": "oklch(0.442 0.017 285.9)", "$type": "color" },
    "secondary-foreground": { "$value": "oklch(1 0 0)", "$type": "color" },
    "accent": { "$value": "oklch(0.552 0.016 286)", "$type": "color" },
    "accent-foreground": { "$value": "oklch(1 0 0)", "$type": "color" },
    "background": { "$value": "oklch(0.985 0 0)", "$type": "color" },
    "foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "card": { "$value": "oklch(1 0 0)", "$type": "color" },
    "card-foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "popover": { "$value": "oklch(1 0 0)", "$type": "color" },
    "popover-foreground": { "$value": "oklch(0.141 0.005 285.9)", "$type": "color" },
    "muted": { "$value": "oklch(0.967 0.001 286)", "$type": "color" },
    "muted-foreground": { "$value": "oklch(0.552 0.016 286)", "$type": "color" },
    "border": { "$value": "oklch(0.922 0.004 286)", "$type": "color" },
    "input": { "$value": "oklch(0.922 0.004 286)", "$type": "color" },
    "ring": { "$value": "oklch(0.21 0.006 285.9)", "$type": "color" },
    "primary-hover": {
      "$value": "color-mix(in oklch, oklch(0.21 0.006 285.9), white 20%)",
      "$type": "color"
    },
    "primary-active": {
      "$value": "color-mix(in oklch, oklch(0.21 0.006 285.9), white 10%)",
      "$type": "color"
    }
  },
  "radius": {
    "sm": { "$value": "0.25rem", "$type": "dimension" },
    "md": { "$value": "0.375rem", "$type": "dimension" },
    "lg": { "$value": "0.5rem", "$type": "dimension" },
    "xl": { "$value": "0.75rem", "$type": "dimension" }
  },
  "fontFamily": {
    "sans": { "$value": "\"Inter\", ui-sans-serif, system-ui, sans-serif", "$type": "fontFamily" },
    "heading": { "$value": "\"Playfair Display\", ui-serif, Georgia, serif", "$type": "fontFamily" }
  },
  "shadow": {
    "sm": { "$value": "0 1px 2px 0 rgb(0 0 0 / 0.03)", "$type": "shadow" },
    "md": { "$value": "0 4px 6px -1px rgb(0 0 0 / 0.07)", "$type": "shadow" },
    "lg": { "$value": "0 10px 15px -3px rgb(0 0 0 / 0.07)", "$type": "shadow" },
    "xl": { "$value": "0 20px 25px -5px rgb(0 0 0 / 0.07)", "$type": "shadow" }
  }
}
