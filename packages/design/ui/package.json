{
  "name": "@nebutra/ui",
  "version": "0.1.0",
  "description": "Unified UI component library — Lobe UI + Radix + HeroUI + layout components",
  "private": false,
  "license": "AGPL-3.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./layout": {
      "types": "./dist/layout/index.d.ts",
      "import": "./dist/layout/index.js"
    },
    "./layouts": {
      "types": "./dist/layouts/index.d.ts",
      "import": "./dist/layouts/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js"
    },
    "./primitives": {
      "types": "./dist/primitives/index.d.ts",
      "import": "./dist/primitives/index.js"
    },
    "./patterns": {
      "types": "./dist/patterns/index.d.ts",
      "import": "./dist/patterns/index.js"
    },
    "./typography": {
      "types": "./dist/typography/index.d.ts",
      "import": "./dist/typography/index.js"
    },
    "./typography/fonts.css": "./dist/typography/fonts.css",
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./tailwind.preset": {
      "types": "./dist/tailwind.preset.d.ts",
      "import": "./dist/tailwind.preset.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:registry": "tsx scripts/build-registry.ts",
    "build": "tsup && tsx scripts/build-registry.ts",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@internationalized/date": "3.12.0",
    "@lobehub/fluent-emoji": "^4.1.0",
    "@lobehub/icons": "^5.0.1",
    "@lobehub/ui": "^5.4.0",
    "@nebutra/brand": "workspace:*",
    "@nebutra/icons": "workspace:*",
    "@number-flow/react": "^0.5.5",
    "@paper-design/shaders-react": "^0.0.71",
    "@phosphor-icons/react": "^2.1.10",
    "@react-types/shared": "^3.33.1",
    "antd": "^6.3.1",
    "antd-style": "^4.1.0",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cobe": "^0.6.5",
    "date-fns": "^4.1.0",
    "dotted-map": "^3.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.35.0",
    "input-otp": "^1.4.2",
    "motion": "^12.35.0",
    "piri": "^1.3.2",
    "react": "^19.2.4",
    "react-ascii-text": "*",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.1",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "react-tweet": "^3.3.0",
    "react-use-measure": "^2.1.7",
    "recharts": "^3.7.0",
    "rough-notation": "^0.5.1",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "usehooks-ts": "^3.1.1",
    "vaul": "^1.1.2"
  },
  "peerDependencies": {
    "@clerk/nextjs": ">=5.0.0",
    "next": ">=14.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "peerDependenciesMeta": {
    "@clerk/nextjs": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nebutra/design-tokens": "workspace:*",
    "@storybook/test": "^8.6.17",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/three": "^0.183.1",
    "next": "^16.2.6",
    "storybook": "^8.6.17",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/design/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/design/ui"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "optionalDependencies": {
    "@react-three/fiber": "^9.5.0",
    "three": "^0.183.2"
  }
}
