{
  "name": "@nebutra/permissions",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "nebutra": {
    "status": "foundation",
    "productionReady": false,
    "requires": [
      "CASL (in-process, no external creds)",
      "or OPENFGA_API_URL + OPENFGA_STORE_ID for Zanzibar-style"
    ],
    "gaps": [
      "OpenFGA adapter is a stub"
    ],
    "featureId": "permissions",
    "category": "iam",
    "summary": "RBAC/ABAC engine — CASL (in-process) + OpenFGA (Zanzibar)"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./casl": "./src/providers/casl.ts",
    "./openfga": "./src/providers/openfga.ts",
    "./react": "./src/react.ts",
    "./middleware": "./src/middleware.ts",
    "./types": "./src/types.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@casl/ability": "^6.7.0",
    "@casl/prisma": "^1.5.1",
    "@nebutra/logger": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "hono": "^4.0.0"
  },
  "peerDependenciesOptional": {
    "hono": true,
    "react": true
  }
}
