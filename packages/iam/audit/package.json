{
  "name": "@nebutra/audit",
  "version": "0.1.0",
  "private": true,
  "description": "Audit logging for sensitive operations",
  "type": "module",
  "nebutra": {
    "status": "wip",
    "productionReady": false,
    "requires": [
      "@nebutra/db",
      "@nebutra/logger"
    ],
    "gaps": [
      "No production app integrations",
      "Event schema not finalized",
      "Retention/export workflow not implemented"
    ]
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./middleware": "./src/middleware.ts",
    "./providers": "./src/providers/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit"
  },
  "dependencies": {
    "@nebutra/db": "workspace:*",
    "@nebutra/logger": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "typescript": "catalog:",
    "vitest": "^4.0.18"
  }
}
