{
  "name": "@nebutra/audit",
  "version": "0.1.1",
  "description": "Audit logging for sensitive operations",
  "private": false,
  "license": "MIT",
  "type": "module",
  "nebutra": {
    "status": "wip",
    "productionReady": false,
    "requires": [
      "@nebutra/db",
      "@nebutra/logger"
    ],
    "gaps": [
      "No production app integrations",
      "Event schema not finalized",
      "Retention/export workflow not implemented"
    ],
    "featureId": "audit",
    "category": "iam",
    "summary": "SOC 2-grade audit logging for sensitive operations"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "@nebutra/logger": "workspace:*",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "@nebutra/db": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@nebutra/db": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nebutra/db": "workspace:*",
    "@types/node": "^22.19.15",
    "typescript": "catalog:",
    "vitest": "^4.0.18"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/iam/audit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/iam/audit"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
