{
  "name": "@nebutra/identity",
  "version": "0.1.0",
  "description": "Provider-agnostic identity adapter layer (Clerk-first, Auth.js-ready)",
  "private": false,
  "license": "AGPL-3.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapters/clerk": {
      "import": "./dist/adapters/clerk.js",
      "types": "./dist/adapters/clerk.d.ts"
    },
    "./adapters/authjs": {
      "import": "./dist/adapters/authjs.js",
      "types": "./dist/adapters/authjs.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@nebutra/contracts": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsup": "^8.5.1",
    "typescript": "catalog:"
  },
  "homepage": "https://github.com/Nebutra/Nebutra-Sailor/tree/main/packages/iam/identity#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nebutra/Nebutra-Sailor.git",
    "directory": "packages/iam/identity"
  },
  "bugs": {
    "url": "https://github.com/Nebutra/Nebutra-Sailor/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
