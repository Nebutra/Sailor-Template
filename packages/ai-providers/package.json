{
  "name": "@nebutra/ai-providers",
  "version": "1.0.0",
  "private": true,
  "description": "Provider registry metadata for Nebutra — meta-only, consumed by @nebutra/create-sailor and docs. Runtime lives in @nebutra/agents.",
  "sideEffects": false,
  "type": "module",
  "nebutra": {
    "status": "stable",
    "productionReady": true,
    "role": "meta-only",
    "runtime": "@nebutra/agents"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./meta": {
      "types": "./dist/meta.d.ts",
      "import": "./dist/meta.js"
    },
    "./templates/*": "./templates/*"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsup": "^8.5.1",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  }
}
