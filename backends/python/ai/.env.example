# ============================================
# Internal service auth (REQUIRED in production)
# ============================================
# Must match SERVICE_SECRET in the Hono gateway.
# Used to verify x-service-token HMAC on every inbound request.
# See packages/iam/auth/src/s2s.ts for the signing algorithm.
SERVICE_SECRET=change-me-in-production

# ============================================
# AI Providers — at least one required
# ============================================

# Default provider selection (siliconflow | openai | openrouter)
DEFAULT_AI_PROVIDER=siliconflow

# Default models (override per request via `model` field)
DEFAULT_MODEL=Qwen/Qwen2.5-72B-Instruct
DEFAULT_EMBEDDING_MODEL=BAAI/bge-m3
DEFAULT_AGENT_MODEL=Qwen/Qwen2.5-72B-Instruct

# SiliconFlow — recommended for CN / cost (https://cloud.siliconflow.cn/account/ak)
SILICONFLOW_API_KEY=sk-xxx
# Set true to use api.siliconflow.com instead of api.siliconflow.cn
SILICONFLOW_USE_INTERNATIONAL=false

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_ORGANIZATION=org-xxx

# OpenRouter — 400+ models via single key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-xxx
OPENROUTER_HTTP_REFERER=https://your-app.com
OPENROUTER_APP_TITLE=Nebutra

# ============================================
# E2B Sandbox
# ============================================
# Get key from https://e2b.dev/dashboard
E2B_API_KEY=e2b_xxx
# Sandbox timeout limits (seconds). Raise to allow longer code executions.
E2B_DEFAULT_TIMEOUT_S=30
E2B_MAX_TIMEOUT_S=120

# ============================================
# Usage metering — go/event-ingest
# ============================================
# POST /api/v1/events receives batched UsageEvent JSON arrays.
# Leave empty to log events locally without forwarding (dev mode).
EVENT_INGEST_URL=http://localhost:8010

# ============================================
# Infrastructure
# ============================================
# Redis (for caching; optional — health check skips if unset)
REDIS_URL=redis://localhost:6379

# ============================================
# Observability
# ============================================
# Set to enable OpenTelemetry tracing (OTLP/gRPC endpoint)
OTEL_EXPORTER_OTLP_ENDPOINT=
LOG_LEVEL=INFO
PORT=8001
